# Cấu hình LLM API (hỗ trợ bất kỳ LLM API nào theo định dạng OpenAI SDK)
# Khuyến nghị dùng mô hình qwen-plus trên nền tảng Alibaba Bailian: https://bailian.console.aliyun.com/
# Lưu ý: mức tiêu thụ khá lớn, hãy thử mô phỏng dưới 40 vòng trước
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Cấu hình đồ thị bộ nhớ ZEP =====
# Hạn mức miễn phí hàng tháng đủ cho sử dụng đơn giản: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Cấu hình LLM tăng tốc (tùy chọn) =====
# Lưu ý: nếu không dùng cấu hình tăng tốc, đừng để các dòng dưới đây trong file .env
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
